{
  "appId": "com.omnisync.app",
  "productName": "OmniSync",
  "artifactName": "OmniSync v${version}-mac-${arch}.${ext}",
  "directories": {
    "output": "dist"
  },
  "files": [
    "main.js",
    "preload.js",
    "appPort.js",
    "package.json",
    "public/**/*",
    ".next/standalone/**/*"
  ],
  "asarUnpack": [
    ".next/standalone/**/*"
  ],
  "mac": {
    "category": "public.app-category.developer-tools",
    "icon": "build/icon.icns",
    "identity": null,
    "target": ["dmg"]
  },
  "win": {
    "target": ["nsis"]
  },
  "linux": {
    "target": ["AppImage"]
  }
}
