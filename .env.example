# OmniSync environment variables (optional)
# Copy to .env.local for local development.

# Encryption key for profile credentials (required outside Electron shell)
# OMNISYNC_ENCRYPTION_SECRET=your-random-secret

# API token for Next.js middleware (auto-generated in dev if unset)
# OMNISYNC_API_TOKEN=

# GitHub OAuth — use your own app or rely on bundled Device Flow
# GITHUB_CLIENT_ID=
# NEXT_PUBLIC_GITHUB_CLIENT_ID=

# Disable bundled OAuth fallback for self-hosted installs
# OMNISYNC_REQUIRE_GITHUB_OAUTH_CONFIG=true
