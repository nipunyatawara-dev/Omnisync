# Optional GitHub OAuth app (web callback flow).
# Device flow works with the bundled public client ID unless disabled below.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Set to "true" to require a custom OAuth app (disables the bundled client ID).
OMNISYNC_REQUIRE_GITHUB_OAUTH_CONFIG=

# Normally set by Electron — do not set these for packaged runs.
# OMNISYNC_API_TOKEN=
# OMNISYNC_ENCRYPTION_SECRET=
# OMNISYNC_USER_DATA_DIR=
